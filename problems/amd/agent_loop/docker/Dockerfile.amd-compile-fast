ARG TARGETPLATFORM=linux/amd64
FROM --platform=${TARGETPLATFORM} ghcr.io/actions/actions-runner:latest

ENV CXX=clang++
ENV DEBIAN_FRONTEND=noninteractive

ARG GPU_ARCH="gfx950"
ENV PYTORCH_ROCM_ARCH=${GPU_ARCH}
ENV ROCM_PATH=/opt/rocm
ENV LD_LIBRARY_PATH=/opt/rocm/lib

RUN sudo apt-get update -y \
    && sudo apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    git \
    sudo \
    cmake \
    ninja-build \
    clang \
    lld \
    wget \
    python3-pip \
    python3-setuptools \
    python3-wheel \
    python3-dev \
    && sudo rm -rf /var/lib/apt/lists/*

RUN sudo groupadd -g 109 render || true

RUN sudo apt-get update -y \
    && sudo usermod -a -G render,video runner \
    && wget https://repo.radeon.com/amdgpu-install/7.1/ubuntu/noble/amdgpu-install_7.1.70100-1_all.deb \
    && sudo apt-get install -y ./amdgpu-install_7.1.70100-1_all.deb \
    && rm -f amdgpu-install_7.1.70100-1_all.deb \
    && sudo apt-get update -y \
    && sudo amdgpu-install -y --usecase=hiplibsdk --no-dkms \
    && sudo rm -rf /var/lib/apt/lists/*

RUN sudo pip install --break-system-packages --no-cache-dir \
    torch==2.10.0+rocm7.1 \
    --index-url https://download.pytorch.org/whl/rocm7.1 \
    && sudo pip install --break-system-packages --no-cache-dir \
    ninja \
    numpy \
    packaging \
    wheel

WORKDIR /workspace
